# ── Supabase (Frontend + Backend) ──────────────────────────────────────────────
SUPABASE_PROJECT_ID=your_project_id
SUPABASE_URL=https://your_project_id.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxx
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
SUPABASE_JWT_SECRET=your_supabase_jwt_secret

# Vite-prefixed versions for the frontend build
VITE_SUPABASE_URL=https://your_project_id.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxx

# ── Backend Server ──────────────────────────────────────────────────────────────
PORT=5001
NODE_ENV=development

# PostgreSQL (only needed when running the standalone Node backend,
# not when using Supabase as the database directly)
DATABASE_URL=postgresql://norocjetx:norocjetx_secret@localhost:5432/norocjetx
POSTGRES_USER=norocjetx
POSTGRES_PASSWORD=norocjetx_secret
POSTGRES_DB=norocjetx

# Redis
REDIS_URL=redis://127.0.0.1:6379

# JWT signing secret (must match Supabase JWT secret in production,
# or use a custom secret for standalone auth)
JWT_SECRET=your_very_long_random_secret_here

# ── Frontend URLs ───────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# Backend API + WebSocket URLs (used by Vite frontend)
VITE_API_URL=http://localhost:5001/api
VITE_WS_URL=ws://localhost:5001/ws
